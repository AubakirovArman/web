[Unit]
Description=NDDA PDF Forensics (FastAPI)
After=network.target

[Service]
Type=simple
WorkingDirectory=/mnt/models/NDDA_AI/8040/pdf-forensics
ExecStart=/mnt/models/NDDA_AI/8040/pdf-forensics/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8050
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
